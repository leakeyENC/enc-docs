# Base URL the "Try It" console sends requests to.
# Host root only — endpoint paths already include the /v1 prefix, so do NOT
# append /v1 or /api (/api on the sandbox host serves Swagger UI, not the API).
# When unset, the console falls back to the hardcoded sandbox base in TryItConsole.tsx.
NEXT_PUBLIC_API_BASE_URL=https://sandbox-new.encryptus.co
